{
  "name": "drone-pipeline-wizard",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform wizard for drone imagery georeferencing and Mapbox tileset upload",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && npx tsx electron/main.ts\"",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && npx tsx electron/main.ts\"",
    "build": "tsc && vite build && electron-builder",
    "build:vite": "tsc && vite build",
    "preview": "vite preview",
    "electron:pack": "electron-builder --dir",
    "electron:make": "electron-builder"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.8",
    "mapbox-gl": "^3.20.0"
  },
  "devDependencies": {
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^38.0.0",
    "electron-builder": "^26.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vite-plugin-electron": "^1.0.4",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "com.toro.drone-pipeline-wizard",
    "productName": "Drone Pipeline Wizard",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "extraFiles": [
      {
        "from": "gdal-bin",
        "to": "gdal-bin",
        "filter": ["**/*"]
      }
    ]
  }
}
